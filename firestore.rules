rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper for Debtor document shape and boundaries
    function isValidDebtor(data) {
      return data.keys().hasAll([
        'id', 'firstName', 'lastName', 'phone', 'amountGiven', 
        'termDays', 'startDate', 'interestPercent', 'markupGiven', 
        'totalExpected', 'dailyInstallment', 'status', 'notes', 
        'repaymentSchedule', 'paymentLogs', 'createdAt'
      ]) 
      && data.id is string && data.id.size() <= 128
      && data.firstName is string && data.firstName.size() <= 100
      && data.lastName is string && data.lastName.size() <= 100
      && data.phone is string && data.phone.size() <= 30
      && data.amountGiven is number && data.amountGiven >= 0
      && data.termDays is number && data.termDays > 0
      && data.startDate is string && data.startDate.size() <= 20
      && data.interestPercent is number && data.interestPercent >= 0
      && data.markupGiven is number && data.markupGiven >= 0
      && data.totalExpected is number && data.totalExpected >= 0
      && data.dailyInstallment is number && data.dailyInstallment >= 0
      && data.status in ['active', 'completed', 'overdue', 'loss']
      && data.notes is string && data.notes.size() <= 5000
      && data.repaymentSchedule is list
      && data.paymentLogs is list
      && data.createdAt is string && data.createdAt.size() <= 30;
    }

    // Validation helper for global app settings
    function isValidSettings(data) {
      return data.keys().hasAll([
        'projectName', 'bgType', 'customBgUrl', 'bgPreset', 'themeColor'
      ])
      && data.projectName is string && data.projectName.size() <= 150
      && data.bgType in ['image', 'gradient', 'solid', 'system']
      && data.customBgUrl is string && data.customBgUrl.size() <= 2048
      && data.bgPreset is string && data.bgPreset.size() <= 200
      && data.themeColor is string && data.themeColor.size() <= 50;
    }

    // Debtors collection rules
    match /debtors/{debtorId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isValidDebtor(request.resource.data);
      allow delete: if request.auth != null;
    }

    // Global settings document rules
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && docId == 'global' && isValidSettings(request.resource.data);
    }
  }
}
